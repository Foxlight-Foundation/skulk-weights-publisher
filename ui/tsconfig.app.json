{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Path aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    /* Types — vitest/globals makes describe/it/vi/expect available in test files */
    "types": ["vite/client", "vitest/globals"],

    /* Strict */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  /* Exclude test and story files from the production build compilation only.
     vitest handles its own transpilation; tsc -b only needs the app source. */
  "exclude": [
    "**/*.test.tsx",
    "**/*.test.ts",
    "**/*.stories.tsx",
    "src/test-setup.ts",
    "vitest.config.ts"
  ]
}
